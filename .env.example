# QQ Mail MCP Server Configuration
# Copy this file to .env and fill in your actual values.

# QQ Mail account and authorization code (NOT login password)
QQMAIL_ADDRESS=your_qq_email@qq.com
QQMAIL_AUTH_CODE=your_authorization_code

# SMTP settings (implicit TLS)
QQMAIL_SMTP_HOST=smtp.qq.com
QQMAIL_SMTP_PORT=465

# IMAP settings (implicit TLS)
QQMAIL_IMAP_HOST=imap.qq.com
QQMAIL_IMAP_PORT=993

# MCP HTTP server settings
MCP_HTTP_BIND=127.0.0.1:3000
MCP_ACCESS_TOKEN=your_secret_access_token_here
