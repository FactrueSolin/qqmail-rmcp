mcp:
  bind: 127.0.0.1:3000
  access_token: your_secret_access_token_here
  # OAuth access/refresh tokens are stored here, not in account config.
  token_store_path: ./config/tokens.local.json

mail:
  accounts:
    personal:
      provider: qq
      address: your_personal@qq.com
      auth_code: your_qq_authorization_code
      smtp:
        host: smtp.qq.com
        port: 465
      imap:
        host: imap.qq.com
        port: 993

    work:
      provider: qq
      address: your_work@qq.com
      auth_code: your_qq_authorization_code
      smtp:
        host: smtp.qq.com
        port: 465
      imap:
        host: imap.qq.com
        port: 993

    gmail:
      provider: gmail
      address: your_account@gmail.com
      oauth:
        client_id: your_google_oauth_client_id
        client_secret: your_google_oauth_client_secret
        redirect_uri: http://127.0.0.1:3000/oauth/callback

    outlook:
      provider: outlook
      address: your_account@outlook.com
      oauth:
        client_id: your_microsoft_app_client_id
        client_secret: your_microsoft_app_client_secret
        redirect_uri: http://127.0.0.1:3000/oauth/callback
        tenant_id: common
